# ── Supabase ──────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Alpaca (US equity real-time prices, /api/prices route) ─────
# Get from: alpaca.markets → sign up → Dashboard → API Keys
# Free tier market data works even on an unfunded/paper account.
# Awaiting account review as of Jul 2026 -- until set, /api/prices
# silently falls back to Yahoo Finance for US symbols (no crash).
ALPACA_API_KEY_ID=your-alpaca-key-id-here
ALPACA_API_SECRET_KEY=your-alpaca-secret-key-here
